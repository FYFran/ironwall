#!/usr/bin/env bash
# ==============================================================================
# Ironwall Pre-Push Hook
# Runs FULL Ironwall scan before pushing to remote.
# More thorough than pre-commit (scans entire repo, not just staged files).
#
# Install: cp hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
# Skip:    IRONWALL_PUSH_SKIP=1 git push
# ==============================================================================

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

IRONWALL_BIN="${IRONWALL_BIN:-ironwall}"
IRONWALL_PUSH_SKIP="${IRONWALL_PUSH_SKIP:-0}"

if [ "$IRONWALL_PUSH_SKIP" = "1" ]; then
    echo -e "${YELLOW}[ironwall] Pre-push skipped (IRONWALL_PUSH_SKIP=1)${NC}"
    exit 0
fi

if ! command -v "$IRONWALL_BIN" &> /dev/null; then
    echo -e "${YELLOW}[ironwall] Not installed — skipping pre-push${NC}"
    exit 0
fi

echo -e "${GREEN}[ironwall] Full scan before push...${NC}"

# Run full scan (not just diff)
SCAN_OUTPUT=$(mktemp)
set +e
"$IRONWALL_BIN" scan . --format terminal 2>&1 | tee "$SCAN_OUTPUT"
SCAN_EXIT=$?
set -e

CRITICAL_COUNT=$(grep -c "CRITICAL" "$SCAN_OUTPUT" 2>/dev/null || echo "0")
HIGH_COUNT=$(grep -c "HIGH" "$SCAN_OUTPUT" 2>/dev/null || echo "0")

if [ "$CRITICAL_COUNT" -gt 0 ]; then
    echo ""
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}  PUSH BLOCKED: $CRITICAL_COUNT CRITICAL finding(s)${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "Options:"
    echo "  1. Fix CRITICAL findings and recommit"
    echo "  2. IRONWALL_PUSH_SKIP=1 git push (emergency only)"
    exit 1
fi

if [ "$HIGH_COUNT" -gt 3 ]; then
    echo -e "${YELLOW}[ironwall] ⚠️ $HIGH_COUNT HIGH findings (>3) — review recommended${NC}"
fi

echo -e "${GREEN}[ironwall] ✅ Pre-push scan passed${NC}"
rm -f "$SCAN_OUTPUT"
exit 0
